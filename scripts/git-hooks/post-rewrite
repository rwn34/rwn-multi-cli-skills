#!/usr/bin/env bash
# =============================================================================
# post-rewrite — auto-sync the 4AI-panes install after a REWRITE that changes
#                tools/4ai-panes/**
# =============================================================================
# Runs under Git-Bash on Windows via core.hooksPath=scripts/git-hooks (ADR-0005).
# post-rewrite fires after commands that rewrite history in place, most notably
# `git rebase` (including the rebase variant of `git pull` and `gh pr merge
# --rebase`). Those paths do NOT fire post-merge because no merge commit is
# created, so without this hook a rebase-merge of a PR that touches
# tools/4ai-panes/** would leave ~/.rwn-auto stale.
#
# Args: $1 = command that triggered the rewrite ("rebase" or "amend").
#       We only act on "rebase"; amend does not change the file tree in a way
#       that needs a re-sync (and the preceding post-commit already handled it).
#
# post-rewrite is a post-event hook by nature: the rewrite already happened, so
# it CANNOT and MUST NOT block. Every path exits 0.
#
# It only decides WHETHER to sync (did this rewrite touch tools/4ai-panes/**);
# the "which files are tool files" question belongs entirely to the PowerShell
# sync script scripts/sync-4ai-panes-install.ps1. See
# docs/specs/4ai-panes-install-sync.md.
# =============================================================================

cmd="$1"

# Amend is covered by post-commit; skip it to avoid a redundant sync pass.
[ "$cmd" = "rebase" ] || exit 0

# Repo root (hook cwd is the repo root, but resolve defensively).
REPO_ROOT="$(git rev-parse --show-toplevel 2>/dev/null)" || exit 0
SYNC_SCRIPT="$REPO_ROOT/scripts/sync-4ai-panes-install.ps1"

# 1. Change range for a rebase: ORIG_HEAD..HEAD captures the rewritten delta.
if ! git rev-parse --verify -q ORIG_HEAD >/dev/null 2>&1; then
    exit 0
fi

changed="$(git diff --name-only ORIG_HEAD HEAD 2>/dev/null)"

# 2. Path filter — cheap: bail silently unless a tool file moved.
if ! printf '%s\n' "$changed" | grep -q '^tools/4ai-panes/'; then
    exit 0
fi

# 3. Locate PowerShell; if absent, warn to stderr and exit 0 (never fail git op).
PS_BIN="$(command -v powershell || command -v pwsh)"
if [ -z "$PS_BIN" ]; then
    echo "post-rewrite: tools/4ai-panes/ changed but neither 'powershell' nor 'pwsh' is on PATH — 4AI-panes install NOT synced. Run scripts/sync-4ai-panes-install.ps1 manually." >&2
    exit 0
fi

# 4. Invoke the sync. On non-zero, print a LOUD stderr warning but STILL exit 0.
if ! "$PS_BIN" -NoProfile -File "$SYNC_SCRIPT"; then
    {
        echo "=============================================================================="
        echo "post-rewrite: 4AI-panes install sync REPORTED ERRORS (rewrite itself is fine)."
        echo "  A tool file may have failed post-copy hash verification, or an allowlisted"
        echo "  source file is missing. The running install may be STALE or PARTIAL."
        echo "  Install path: \${RWN_AUTO_INSTALL_DIR:-~/.rwn-auto/rwn-4AI-panes}"
        echo "  Re-run manually to inspect:"
        echo "    powershell -NoProfile -File scripts/sync-4ai-panes-install.ps1 -DryRun"
        echo "=============================================================================="
    } >&2
fi

exit 0
