#!/usr/bin/env bash
# =============================================================================
# post-merge — auto-sync the 4AI-panes install when tools/4ai-panes/** changes
# =============================================================================
# Runs under Git-Bash on Windows via core.hooksPath=scripts/git-hooks (ADR-0005).
# post-merge fires after `git pull` / `git merge` advances HEAD. It is a
# post-event hook by nature: it CANNOT and MUST NOT block. Every path exits 0.
#
# It only decides WHETHER to sync (did this merge touch tools/4ai-panes/**);
# the "which files are tool files" question belongs entirely to the PowerShell
# sync script scripts/sync-4ai-panes-install.ps1. See
# docs/specs/4ai-panes-install-sync.md.
# =============================================================================

# Repo root (hook cwd is the repo root, but resolve defensively).
REPO_ROOT="$(git rev-parse --show-toplevel 2>/dev/null)" || exit 0
SYNC_SCRIPT="$REPO_ROOT/scripts/sync-4ai-panes-install.ps1"

# --- reverse-write-detector (warn-only, primary-checkout-only) -------------
# Runs unconditionally on every merge (cheap: bounded git ls-tree/hash-object
# per stable .ai/** path, see .ai/tools/reverse-write-detector.sh). Guarded to
# the PRIMARY checkout only — a linked worktree's --git-dir differs from its
# --git-common-dir, a primary checkout's does not. Never blocks: any failure
# here is a warning, exit stays 0.
if [ "$(git rev-parse --path-format=absolute --git-dir 2>/dev/null)" = \
     "$(git rev-parse --path-format=absolute --git-common-dir 2>/dev/null)" ]; then
    rwd_out="$(bash "$REPO_ROOT/.ai/tools/reverse-write-detector.sh" 2>&1)"
    if printf '%s\n' "$rwd_out" | grep -q '^REVERSE-WRITE:'; then
        {
            echo "=============================================================================="
            echo "post-merge: reverse-write-detector found stable .ai/** paths that look clobbered"
            echo "  (content matches an OLDER committed blob, not origin/master's current one)."
            printf '%s\n' "$rwd_out"
            echo "  See docs/specs/junction-reverse-write-guard.md for the mechanism + recovery."
            echo "=============================================================================="
        } >&2
    fi
fi

# 1. Determine the change range. ORIG_HEAD..HEAD is the merge delta.
if ! git rev-parse --verify -q ORIG_HEAD >/dev/null 2>&1; then
    exit 0   # no ORIG_HEAD (nothing merged we can diff) — nothing to do.
fi

changed="$(git diff --name-only ORIG_HEAD HEAD 2>/dev/null)"

# 2. Path filter — cheap: bail silently unless a tool file moved.
if ! printf '%s\n' "$changed" | grep -q '^tools/4ai-panes/'; then
    exit 0
fi

# 3. Locate PowerShell; if absent, warn to stderr and exit 0 (never fail git op).
PS_BIN="$(command -v powershell || command -v pwsh)"
if [ -z "$PS_BIN" ]; then
    echo "post-merge: tools/4ai-panes/ changed but neither 'powershell' nor 'pwsh' is on PATH — 4AI-panes install NOT synced. Run scripts/sync-4ai-panes-install.ps1 manually." >&2
    exit 0
fi

# 4. Invoke the sync. On non-zero, print a LOUD stderr warning but STILL exit 0.
if ! "$PS_BIN" -NoProfile -File "$SYNC_SCRIPT"; then
    {
        echo "=============================================================================="
        echo "post-merge: 4AI-panes install sync REPORTED ERRORS (merge itself is fine)."
        echo "  A tool file may have failed post-copy hash verification, or an allowlisted"
        echo "  source file is missing. The running install may be STALE or PARTIAL."
        echo "  Install path: \${RWN_AUTO_INSTALL_DIR:-~/.rwn-auto/rwn-4AI-panes}"
        echo "  Re-run manually to inspect:"
        echo "    powershell -NoProfile -File scripts/sync-4ai-panes-install.ps1 -DryRun"
        echo "=============================================================================="
    } >&2
fi

exit 0
