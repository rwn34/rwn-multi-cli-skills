#!/usr/bin/env bash
# =============================================================================
# Universal cross-CLI commit backstop  (ADR-0005)
# =============================================================================
# Repo-level git pre-commit hook, versioned and wired via `core.hooksPath`.
# It is the ONE mechanical enforcement layer that fires for EVERY CLI regardless
# of runtime: headless (`kimi -p`), trust-all (`kiro --trust-all-tools`),
# subagent, or hookless-default agents — all of them ultimately run `git commit`,
# and this hook sits on that chokepoint.
#
# It cannot stop a bad *write*; it stops a bad write from being *committed*
# (the action that actually corrupts shared cross-CLI state). See
# .ai/reports/claude-2026-07-09-validation-rollup.md §4 for the rationale.
#
# PURE bash/sed. NO python: the per-CLI hooks failed open because python3 on this
# host is a WindowsApps alias stub (empty stdout, exit 0). Do not reintroduce it.
#
# Owner override (in a pinch): `git commit --no-verify`.
#
# Sourcing with PRECOMMIT_LIB=1 defines the decision functions WITHOUT running the
# hook — this is how scripts/git-hooks/test-pre-commit.sh exercises the logic.
# =============================================================================

# ---- Decision functions (pure; testable) -----------------------------------

# _lc <path> — echo the path lowercased. On case-insensitive filesystems
# (Windows NTFS, default macOS APFS) `.ENV`, `ID_RSA`, `.Kimi/` name the SAME
# file as `.env`, `id_rsa`, `.kimi/`, so guards must match case-insensitively or
# they fail OPEN. Matching on the lowercased path keeps the guard fail-CLOSED
# without changing WHICH patterns/territories are blocked.
_lc() { printf '%s' "$1" | tr '[:upper:]' '[:lower:]'; }

# _is_sensitive <path> — 0 if the path is a secret/credential file (any depth).
_is_sensitive() {
    set -- "$(_lc "$1")"
    case "$1" in
        .env|.env.*|*/.env|*/.env.*)                          return 0 ;;
        *.key|*.pem|*.p12|*.pfx)                              return 0 ;;
        id_rsa*|*/id_rsa*|id_ed25519*|*/id_ed25519*)          return 0 ;;
        .aws/*|*/.aws/*|.ssh/*|*/.ssh/*)                      return 0 ;;
        secrets.*|*/secrets.*)                                return 0 ;;
        credentials*|*/credentials*)                          return 0 ;;
    esac
    return 1
}

# _is_tombstone <path> — 0 if the path is under a removed-graph dir.
# KimiGraph/KiroGraph were removed 2026-07-09 (ADR-0003 amendment); nothing
# should ever be committed under these paths again.
_is_tombstone() {
    set -- "$(_lc "$1")"
    case "$1" in
        .kimigraph|.kimigraph/*|.kirograph|.kirograph/*) return 0 ;;
    esac
    return 1
}

# Path to the SSOT source→replica registry. Overridable for tests; the hook body
# runs from the repo root, so the relative default resolves there.
: "${SYNC_MD:=.ai/sync.md}"

# _is_sync_replica <path> — 0 if <path> is enumerated as a replica destination in
# the SSOT registry .ai/sync.md (fixed-string match, no regex). Fails CLOSED
# (returns 1 = not a replica) if the registry is missing or unreadable, so a
# vanished registry can never widen the exception below.
_is_sync_replica() {
    [ -r "$SYNC_MD" ] || return 1
    grep -qF "$1" "$SYNC_MD"
}

# _territory_violation <committer> <path> — 0 if <committer> may NOT commit <path>
# because it lives in ANOTHER CLI's config dir. Shared .ai/ is writable by all
# (except OpenCode, whose lane is a strict whitelist). Source writes by
# claude/kimi/kiro are fine — this catches WRONG-CLI writes to config dirs.
_territory_violation() {
    committer="$1"; p="$(_lc "$2")"
    case "$committer" in
        claude-code)
            case "$p" in
                # SSOT replica exception (ADR-0005 amendment 2026-07-10, WIDENED
                # 2026-07-12): claude-code MAY commit ANY path under another CLI's
                # dir ONLY when that exact path is a replica registered in
                # .ai/sync.md. Originally steering-only; widened to the full replica
                # set so the two non-steering replicas
                # (.kimi/resource/karpathy-guidelines-examples.md,
                # .kiro/skills/karpathy-guidelines/SKILL.md) land in the same atomic
                # SSOT commit. Hand-authored non-replicas (00-ai-contract.md, hooks,
                # agents) stay blocked. The lookup uses the ORIGINAL-case path ($2),
                # not the lowercased $p, so an uppercase SKILL.md matches the registry
                # verbatim and any case-variant fails CLOSED (blocked).
                .kimi/*|.kiro/*)
                    _is_sync_replica "$2" && return 1
                    return 0 ;;
            esac ;;
        kimi-cli)
            case "$p" in .claude/*|.kiro/*|.opencode/*|opencode.json) return 0 ;; esac ;;
        kiro-cli)
            case "$p" in .claude/*|.kimi/*|.opencode/*|opencode.json) return 0 ;; esac ;;
        opencode)
            # OpenCode's lane is a whitelist — it must stay in lockstep with
            # WRITABLE_LANE in .opencode/plugin/framework-guard.js (the write-time
            # half of the same rule; this is the commit-time half).
            #
            # ADR-0010 Wave-3 (2026-07-21): the activity log is an entry-per-file
            # spool under .ai/activity/entries/*. The rendered .ai/activity/log.md
            # is generated and must NOT be committed.
            # Deliberately NOT added: .ai/activity/archive/* — archival is a `git mv`
            # run by Claude/the owner, not OpenCode's job.
            case "$p" in
                .ai/activity/entries/*)                 return 1 ;;
                .ai/reports/*|.ai/handoffs/*|.github/*) return 1 ;;
                *) return 0 ;;
            esac ;;
        *)
            # Unknown / unset committer → strictest: block ALL CLI-owned config dirs.
            case "$p" in .claude/*|.kimi/*|.kiro/*|.opencode/*) return 0 ;; esac ;;
    esac
    return 1
}

# _root_new_violation <path> — 0 if <path> is a repo-root file (no slash) NOT in
# the ADR-0001 allowlist. Mirrors .claude/hooks/pretool-write-edit.sh Rule 3.
# Caller applies this ONLY to newly-added files.
_root_new_violation() {
    p="$1"
    case "$p" in
        */*) return 1 ;;   # has slash → not at root
        "")  return 1 ;;
    esac
    case "$p" in
        # Category A — docs entry points
        AGENTS.md|README.md|CLAUDE.md)                  return 1 ;;
        LICENSE|LICENSE.*)                              return 1 ;;
        CHANGELOG|CHANGELOG.*)                          return 1 ;;
        CONTRIBUTING.md|SECURITY.md|CODE_OF_CONDUCT.md) return 1 ;;
        # Category B — git-mandated dotfiles
        .gitignore|.gitattributes)                      return 1 ;;
        # Category C — editor-mandated dotfile
        .editorconfig)                                  return 1 ;;
        # Category D — platform / CI-vendor dotfiles at root
        .dockerignore|.gitlab-ci.yml)                   return 1 ;;
        # Category E — MCP convention + OpenCode config
        .mcp.json|.mcp.json.example|opencode.json)      return 1 ;;
    esac
    return 0   # at root, not allowlisted → violation
}

# ---- PowerShell syntax gate -------------------------------------------------
# A .ps1 that does not PARSE must never enter history: the post-commit sync hook
# deploys scripts toward the owner's LIVE launcher, so a broken script committed
# here becomes a broken script running there. The sync script's own parse gate is
# the LAST line of defense; this is the FIRST — refuse the commit itself.
#
# PORTABILITY: this gate is a no-op where no PowerShell host exists (Linux CI,
# the test suite on ubuntu). It SKIPS gracefully rather than failing — a commit
# must never be blocked just because the machine cannot run the check. It is
# enforced where it matters: the owner's Windows box, which is the only place a
# .ps1 actually executes.

# _ps_host — echo the available PowerShell binary ('pwsh' or 'powershell'), or
# nothing at all when neither is on PATH (→ callers skip the gate).
_ps_host() {
    if command -v pwsh >/dev/null 2>&1; then
        printf 'pwsh'
    elif command -v powershell >/dev/null 2>&1; then
        printf 'powershell'
    fi
}

# _ps1_parse_error <file> — 0 if <file> has a PowerShell SYNTAX error, with a
# "line N: message" summary left in PS1_ERR. Returns 1 (allow) if the file parses
# cleanly, if no PowerShell host is available, or if the host itself failed to
# produce a verdict — we block only on a DEFINITIVE parse error, never on broken
# tooling.
PS1_ERR=""
_ps1_parse_error() {
    PS1_ERR=""
    _psh="$(_ps_host)"
    [ -n "$_psh" ] || return 1          # no PowerShell → graceful skip

    # PowerShell needs a native path; Git Bash hands us an MSYS one.
    _pspath="$1"
    if command -v cygpath >/dev/null 2>&1; then
        _pspath="$(cygpath -w "$1")" || return 1
    fi

    _psout="$("$_psh" -NoProfile -NonInteractive -Command "\$t=\$null; \$e=\$null; [void][System.Management.Automation.Language.Parser]::ParseFile('$_pspath', [ref]\$t, [ref]\$e); if (\$e -and \$e.Count -gt 0) { \$x=\$e[0]; Write-Output ('line ' + \$x.Extent.StartLineNumber + ': ' + \$x.Message) } else { Write-Output 'OK' }" 2>/dev/null | tr -d '\r')"

    case "$_psout" in
        line\ *) PS1_ERR="$_psout"; return 0 ;;   # definitive syntax error → block
        *)       return 1 ;;                      # 'OK', or host produced nothing → allow
    esac
}

# When sourced as a library, stop here (do not run the hook body).
if [ -n "$PRECOMMIT_LIB" ]; then
    return 0 2>/dev/null || exit 0
fi

# ---- Hook body -------------------------------------------------------------

# Committer identity drives the cross-CLI territory rule.
committer_raw="$(git config user.name 2>/dev/null)"
case "$committer_raw" in
    claude-code|kimi-cli|kiro-cli|opencode) committer="$committer_raw" ;;
    *) committer="unknown" ;;   # fail-CLOSED: strictest interpretation
esac

fail_closed() {
    echo "pre-commit (ADR-0005): $1 — refusing to fail open. Fix or use 'git commit --no-verify'." >&2
    exit 1
}

# ---- SSOT auto-sync (ADR-0005 second amendment, 2026-07-12) -----------------
# A staged change to an SSOT source (.ai/instructions/**) must land ATOMICALLY
# with its regenerated replicas, or the drift gate (.ai/tools/check-ssot-drift.sh)
# goes red in CI and throttles the Tier-B auto-merge. sync-replicas.sh is the ONE
# generator; the drift checker calls the same code, so they cannot disagree.
#
#   * committer claude-code (the fleet git operator): regenerate IN PLACE and
#     stage the replicas into THIS commit — the autonomy the owner approved. The
#     widened territory exception (above) lets those replica paths through.
#   * any other identity (human / unknown): NEVER silently mutate the commit.
#     Regenerate into a throwaway tree, compare against what is staged, and REFUSE
#     with a clear hint if any replica is missing/stale.
#
# If sync-replicas.sh aborts (e.g. an SSOT source carries skip-worktree because a
# bootstrapped worktree's reverse-write guard is active), the abort MUST propagate
# and the commit must fail loudly.  Stderr is captured and echoed so the committer
# sees the exact source path and the fix (`git update-index --no-skip-worktree`).
ssot_staged="$(git diff --cached --name-only -- .ai/instructions/ 2>/dev/null)"
if [ -n "$ssot_staged" ]; then
    gen=".ai/tools/sync-replicas.sh"
    [ -r "$gen" ] || fail_closed "SSOT source staged but generator missing ($gen)"

    if [ "$committer" = "claude-code" ]; then
        gen_out="$(mktemp)"; gen_err="$(mktemp)"
        bash "$gen" >"$gen_out" 2>"$gen_err"; grc=$?
        manifest="$(cat "$gen_out")"
        rm -f "$gen_out"
        if [ "$grc" -ne 0 ]; then
            { echo "sync-replicas.sh refused to regenerate replicas:"; cat "$gen_err"; } >&2
            rm -f "$gen_err"
            fail_closed "SSOT source may be skip-worktree or another generator error (see above)"
        fi
        rm -f "$gen_err"
        while IFS="$(printf '\t')" read -r _src dst; do
            [ -n "$dst" ] || continue
            git add -- "$dst" 2>/dev/null || fail_closed "could not stage regenerated replica: $dst"
        done <<EOF
$manifest
EOF
    else
        gtmp="$(mktemp -d)" || fail_closed "mktemp failed"
        gen_out="$(mktemp)"; gen_err="$(mktemp)"
        bash "$gen" --dest-root "$gtmp" >"$gen_out" 2>"$gen_err"; grc=$?
        manifest="$(cat "$gen_out")"
        rm -f "$gen_out"
        if [ "$grc" -ne 0 ]; then
            { echo "sync-replicas.sh refused to regenerate replicas:"; cat "$gen_err"; } >&2
            rm -f "$gen_err"; rm -rf "$gtmp"
            fail_closed "SSOT source may be skip-worktree or another generator error (see above)"
        fi
        rm -f "$gen_err"
        stale=""
        while IFS="$(printf '\t')" read -r _src dst; do
            [ -n "$dst" ] || continue
            # Compare the STAGED (index) content against the freshly generated one.
            if ! git show ":$dst" 2>/dev/null | diff -q - "$gtmp/$dst" >/dev/null 2>&1; then
                stale="${stale}  - ${dst}
"
            fi
        done <<EOF
$manifest
EOF
        rm -rf "$gtmp"
        if [ -n "$stale" ]; then
            {
                echo "=============================================================================="
                echo "COMMIT REJECTED — SSOT changed without matching replicas (ADR-0005)"
                echo "=============================================================================="
                echo "Committer (git config user.name): ${committer_raw:-<unset>}  →  policy identity: '$committer'"
                echo
                echo "You staged a change under .ai/instructions/ (the SSOT), but these CLI-native"
                echo "replicas are missing or stale in the commit:"
                printf '%s' "$stale"
                echo "SSOT changed; run 'bash .ai/tools/sync-replicas.sh' and re-stage the replicas,"
                echo "or commit as claude-code (the fleet operator auto-stages them)."
                echo
                echo "Owner override (in a pinch):  git commit --no-verify"
                echo "=============================================================================="
            } >&2
            exit 1
        fi
    fi
fi

# ---- Activity-log append-only gate (ADR-0010 Wave-3, 2026-07-21) ------------
# The activity log is an entry-per-file spool under .ai/activity/entries/*.md.
# Entries are append-only: a commit must not DELETE an existing entry file.
# (Moving the pre-spool archive into .ai/activity/archive/ is a deliberate
# administrative git mv and is allowed; individual entry deletions are not.)
entry_deletions="$(git diff --cached --diff-filter=D --name-only -- .ai/activity/entries/ 2>/dev/null)"
if [ -n "$entry_deletions" ]; then
    {
        echo "=============================================================================="
        echo "COMMIT REJECTED — activity-log entry deletion detected (ADR-0010)"
        echo "=============================================================================="
        printf '%s\n' "$entry_deletions" | sed 's/^/  - /'
        echo
        echo "Entry files under .ai/activity/entries/ are append-only. To retire old"
        echo "entries, move them to .ai/activity/archive/; do not delete them."
        echo
        echo "Owner override (in a pinch):  git commit --no-verify"
        echo "=============================================================================="
    } >&2
    exit 1
fi

# Reject any attempt to commit CONTENT for the generated view .ai/activity/log.md.
# --no-renames --diff-filter=d deliberately exempts REMOVING the path: the ADR-0010
# Wave-3 freeze archives the pre-spool log with `git mv log.md archive/log-pre-spool.md`,
# and a plain --name-only check matched that rename's old path, so this guard blocked
# the very freeze it exists to enforce. --no-renames decomposes the rename into
# D(old)+A(new) and --diff-filter=d drops the D, while a genuine add/modify of the
# generated view is still an A/M and is still refused.
log_staged="$(git diff --cached --no-renames --name-only --diff-filter=d -- .ai/activity/log.md 2>/dev/null)"
if [ -n "$log_staged" ]; then
    {
        echo "=============================================================================="
        echo "COMMIT REJECTED — generated activity-log view is staged (ADR-0010)"
        echo "=============================================================================="
        echo ".ai/activity/log.md is a generated view. Add it to .gitignore, unstage it,"
        echo "and regenerate it locally with 'bash .ai/tools/render-activity-log.sh' when needed."
        echo
        echo "Owner override (in a pinch):  git commit --no-verify"
        echo "=============================================================================="
    } >&2
    exit 1
fi

# Gather staged paths (NUL-delimited). Fail CLOSED if git cannot enumerate them.
tmp_all="$(mktemp)" || fail_closed "mktemp failed"
if ! git diff --cached --name-only -z > "$tmp_all" 2>/dev/null; then
    rm -f "$tmp_all"
    fail_closed "could not list staged files (git diff --cached failed)"
fi

tmp_add="$(mktemp)" || { rm -f "$tmp_all"; fail_closed "mktemp failed"; }
if ! git diff --cached --diff-filter=A --name-only -z > "$tmp_add" 2>/dev/null; then
    rm -f "$tmp_all" "$tmp_add"
    fail_closed "could not list added files (git diff --cached failed)"
fi

offenders=""

# Pass 1 — all staged paths: sensitive, tombstone, cross-CLI territory.
while IFS= read -r -d '' p; do
    [ -z "$p" ] && continue
    p="$(printf '%s' "$p" | tr '\\' '/')"
    reason=""
    if _is_sensitive "$p"; then
        reason="sensitive/secret file — never commit credential material"
    elif _is_tombstone "$p"; then
        reason="removed-graph tombstone (.kimigraph/ or .kirograph/, ADR-0003) — do not recreate"
    elif _territory_violation "$committer" "$p"; then
        reason="cross-CLI territory — committer '$committer' may not commit this path"
    fi
    [ -n "$reason" ] && offenders="${offenders}  - ${p}
      ${reason}
"
done < "$tmp_all"

# Pass 2 — newly-added paths only: root-file policy (ADR-0001).
while IFS= read -r -d '' p; do
    [ -z "$p" ] && continue
    p="$(printf '%s' "$p" | tr '\\' '/')"
    if _root_new_violation "$p"; then
        offenders="${offenders}  - ${p}
      new root-level file not in ADR-0001 allowlist (docs/architecture/0001-root-file-exceptions.md)
"
    fi
done < "$tmp_add"

# Pass 3 — staged .ps1 files: PowerShell syntax gate (skips where no PS host).
# Parses the STAGED CONTENT (git show ":$p"), not the working tree — a file that
# is clean on disk but broken in the index must still be caught.
if [ -n "$(_ps_host)" ]; then
    while IFS= read -r -d '' p; do
        [ -z "$p" ] && continue
        p="$(printf '%s' "$p" | tr '\\' '/')"
        case "$(_lc "$p")" in *.ps1) ;; *) continue ;; esac

        tmp_ps="$(mktemp)" || { rm -f "$tmp_all" "$tmp_add"; fail_closed "mktemp failed"; }
        # Deleted-but-staged paths have no blob to show → nothing to parse.
        if git show ":$p" > "$tmp_ps" 2>/dev/null; then
            if _ps1_parse_error "$tmp_ps"; then
                offenders="${offenders}  - ${p}
      PowerShell syntax error in the STAGED content — ${PS1_ERR}
"
            fi
        fi
        rm -f "$tmp_ps"
    done < "$tmp_all"
fi

rm -f "$tmp_all" "$tmp_add"

if [ -n "$offenders" ]; then
    {
        echo "=============================================================================="
        echo "COMMIT REJECTED — scripts/git-hooks/pre-commit (ADR-0005 governance backstop)"
        echo "=============================================================================="
        echo "Committer (git config user.name): ${committer_raw:-<unset>}  →  policy identity: '$committer'"
        echo
        echo "Offending staged paths:"
        printf '%s' "$offenders"
        echo "Fix: unstage the path(s)  ->  git reset <path>"
        echo "     route cross-CLI changes through .ai/handoffs/ (the correct CLI commits them)."
        echo "     sensitive files must never be committed."
        echo "     .ps1 syntax errors: fix the script, then RE-STAGE it (the gate reads the"
        echo "     staged content, so a working-tree-only fix will not clear it)."
        echo
        echo "Owner override (in a pinch):  git commit --no-verify"
        echo "=============================================================================="
    } >&2
    exit 1
fi

exit 0
