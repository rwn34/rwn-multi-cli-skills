# ---- OS ----
.DS_Store
Thumbs.db
desktop.ini

# ---- Editors ----
.vscode/
!.vscode/settings.json
!.vscode/extensions.json
!.vscode/tasks.json
!.vscode/launch.json
.idea/
*.swp
*.swo
*~
*.iml

# ---- Build artifacts (language-agnostic; specific languages add their own when chosen) ----
dist/
build/
out/
target/
node_modules/
__pycache__/
*.pyc
*.pyo
.next/
.turbo/
.cache/
coverage/
.nyc_output/
htmlcov/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.tox/

# ---- Logs ----
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ---- Secrets (the sensitive-file hook also blocks writes — this prevents accidental commits) ----
.env
.env.local
.env.*.local
*.key
*.pem
id_rsa*
id_ed25519*
.aws/
.ssh/

# ---- AI CLI local / personal overrides (shared config is committed; personal settings are not) ----
.claude/settings.local.json
.kimi/*.local.*
.kiro/*.local.*

# ---- MCP local config (the .example is committed; the actual .mcp.json is personal) ----
.mcp.json

# ---- Runtime / temp ----
*.tmp
*.temp
.tmp/
.temp/

# ---- Persistence stores ----
*.sqlite
*.sqlite3
*.db

# ---- Platform-specific ----
.gradle/
.vs/

# ---- MCP runtime cache (Playwright MCP server scratch dir) ----
.playwright-mcp/

# ---- Code knowledge graphs (local DBs and caches; config.json may be committed) ----
.codegraph/*
!.codegraph/config.json
.kirograph/*
!.kirograph/config.json
.kimigraph/*
!.kimigraph/config.json

# ---- Sanctioned ephemeral scratch space ----
# ephemeral one-off scripts + probe artifacts — never committed
/.scratch/*
!/.scratch/README.md

# ---- Per-project claim sidecars (pane-runner; ephemeral runtime state) ----
.ai/.claim-*.json

# ---- Pane liveness heartbeat sidecars (fleet-health.sh; ephemeral runtime state) ----
.ai/.heartbeat-*.json

# ---- Per-handoff claim sidecars (ADR-0009 section 3; ephemeral runtime state) ----
# ignore the sidecars but keep the contract README. Must ignore the dir CONTENTS
# (dir/*) not the dir itself, else the README negation cannot take effect.
.ai/handoffs/.claims/*
!.ai/handoffs/.claims/README.md

# ---- Per-handoff quarantine sidecars (poison-pill guard; ephemeral runtime state) ----
# Same pattern as .claims: ignore the sidecars, keep the contract README.
.ai/handoffs/.quarantine/*
!.ai/handoffs/.quarantine/README.md

# ---- Agent worktrees (transient; created/removed by the Agent tool — never commit) ----
.claude/worktrees/
