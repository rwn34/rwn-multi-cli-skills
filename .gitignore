# ---- Secrets (the sensitive-file hook also blocks writes — this prevents accidental commits) ----
.env
.env.local
.env.*.local
*.key
*.pem
id_rsa*
id_ed25519*
.aws/
.ssh/

# ---- AI CLI local / personal overrides (shared config is committed; personal settings are not) ----
.claude/settings.local.json
.kimi/*.local.*
.kiro/*.local.*

# ---- MCP local config (the .example is committed; the actual .mcp.json is personal) ----
.mcp.json

# ---- Runtime / temp ----
*.tmp
*.temp
.tmp/
.temp/

# ---- Persistence stores ----
*.sqlite
*.sqlite3
*.db

# ---- Platform-specific ----
.gradle/
.vs/
